@@ -2269,6 +2318,11 @@ function prepareFreshStack(root: FiberRoot, lanes: Lanes): Fiber {
 
   finishQueueingConcurrentUpdates();
 
+  // Signal seam: a fresh stack begins (or, for NoLanes, resets) the render
