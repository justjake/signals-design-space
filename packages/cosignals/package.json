{
  "name": "cosignals",
  "version": "0.1.0",
  "private": true,
  "description": "Concurrent signals for React",
  "type": "module",
  "sideEffects": [
    "./src/react/index.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./ssr": "./src/ssr.ts",
    "./react": "./src/react/index.ts",
    "./debug": "./src/debug/index.ts",
    "./unstable": "./src/unstable.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "format-doc-comments": "node tools/format-doc-comments.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:react18": "COSIGNALS_REACT=18 vitest run",
    "fuzz": "vitest run tests/oracle-fuzz.spec.ts",
    "bench": "node bench/react-bench.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^26.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "reactive-framework-test-suite": "0.0.2",
    "scheduler": "0.27.0",
    "typescript": "7.0.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "scheduler": ">=0.23.0"
  }
}
