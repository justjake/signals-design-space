-        ' but this renderer was built for v' +
-        EXTERNAL_RUNTIME_PROTOCOL_VERSION +
-        '. The react package and the renderer must come from the same ' +
-        'cosignal fork build.',
-    );
+  if (runtime !== null) {
+    runtime.providers.push(methods);
