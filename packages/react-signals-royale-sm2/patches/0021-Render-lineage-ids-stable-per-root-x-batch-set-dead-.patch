+      }
+      const rootA = ReactNoop.createRoot();
+      await act(() => {
+        rootA.render(<CompA />);
+      });
+      assertLog(['A on=false']);
+      const containerA = events.passes[events.passes.length - 1].container;
+      const rootB = ReactNoop.createRoot();
+      await act(() => {
+        rootB.render(<CompB />);
