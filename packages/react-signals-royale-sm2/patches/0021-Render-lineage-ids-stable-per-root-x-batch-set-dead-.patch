+      });
+      expect(checkFrameInvariants(events.log)).toEqual([]);
+      unsubscribe();
+    });
+
+    it('token-free batches do not share a lineage across events', async () => {
+      const {events, unsubscribe} = subscribe();
+      let setValue;
+      function App() {
+        const [value, _setValue] = useState(0);
