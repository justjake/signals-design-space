+      expect(t2).not.toBe(t1);
+
+      const soloPass = events.passes.find(
+        p => p.included.includes(t1) && !p.included.includes(t2),
+      );
+      const jointPass = events.passes.find(
+        p => p.included.includes(t1) && p.included.includes(t2),
