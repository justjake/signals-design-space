+      expect(soloPass).not.toBe(undefined);
+      expect(jointPass).not.toBe(undefined);
+      // {t1} and {t1, t2} are different batch-sets: different lineages.
+      expect(jointPass.lineage).not.toBe(soloPass.lineage);
+
+      await act(() => {
