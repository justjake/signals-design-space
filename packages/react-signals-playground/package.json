{
	"name": "react-signals-playground",
	"version": "0.0.0",
	"private": true,
	"description": "Vite + React playground that renders one shared App under one entrypoint per concurrent-signals implementation, each at its own named path; '/' redirects to the default (royale-fx2). App code imports everything reactive from '#concurrent-signals-shim'; the page path decides which implementation that specifier resolves to.",
	"license": "MIT",
	"type": "module",
	"imports": {
		"#concurrent-signals-shim": "./src/shims/index.ts"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p battery/tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p battery/tsconfig.json",
		"battery": "playwright test -c battery",
		"devtools-e2e": "playwright test -c devtools-e2e"
	},
	"dependencies": {
		"concurrent-solid-react": "workspace:*",
		"cosignals": "workspace:*",
		"cosignals-alt-a": "workspace:*",
		"cosignals-alt-b": "workspace:*",
		"cosignals-react": "workspace:*",
		"signals-devtools": "workspace:*",
		"signals-royale-fx2": "workspace:*",
		"react": "*",
		"react-dom": "*",
		"signals-royale-fx2-dalien": "workspace:*"
	},
	"devDependencies": {
		"@playwright/test": "1.61.1",
		"@types/node": "24.13.2",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "6.0.2",
		"typescript": "7.0.2",
		"vite": "8.1.0"
	}
}
