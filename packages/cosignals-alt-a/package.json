{
	"name": "cosignals-alt-a",
	"version": "0.1.0",
	"private": true,
	"description": "Variant A implementation of the react-concurrent-signals-arena-alt-a spec: canonical typed-array signals kernel + tapes/write gate + plane W overlay with certificates, driven by a scriptable React fork test double and a randomized oracle. Monotonic write-gate activation, exact React lane parity, no strictLanes flag.",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./tracing": "./src/tracing.ts",
		"./debug": "./src/debug/layout.debug.ts",
		"./react": "./src/react/index.ts"
	},
	"scripts": {
		"check": "tsc --noEmit -p tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "vitest run",
		"gen": "node --experimental-strip-types tools/gen-layout.ts"
	},
	"dependencies": {
		"react-signals-utils": "workspace:*"
	},
	"devDependencies": {
		"@lab/arena": "workspace:*",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"esbuild": "0.28.1",
		"jsdom": "^26.1.0",
		"react": "*",
		"react-dom": "*",
		"reactive-framework-test-suite": "0.0.2",
		"typescript": "6.0.3",
		"vitest": "4.1.6"
	}
}
