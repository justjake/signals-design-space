{
  "name": "cosignals-devtools",
  "version": "0.1.0",
  "description": "Devtools for cosignals: a live dependency-graph explorer and a causal event log that answers \"why did this re-render?\" — mounted inline in your app or as a Chrome DevTools panel.",
  "license": "MIT",
  "author": "Jake Teton-Landis <just.1.jake@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justjake/signals-design-space.git",
    "directory": "packages/devtools"
  },
  "homepage": "https://github.com/justjake/signals-design-space/tree/main/packages/devtools#readme",
  "bugs": "https://github.com/justjake/signals-design-space/issues",
  "keywords": [
    "cosignals",
    "signals",
    "react",
    "devtools",
    "debugger",
    "debugging",
    "tracing",
    "dependency-graph",
    "state-management",
    "chrome-extension"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./protocol": "./src/protocol.ts",
    "./collector": "./src/collector.ts",
    "./cosignals": "./src/cosignals.ts",
    "./cosignals-arena": "./src/cosignals-arena.ts",
    "./panel": "./src/panel/mount.tsx",
    "./button": "./src/panel/DevtoolsPanelButton.tsx",
    "./vite": "./src/vite.ts",
    "./engine": "./src/engine.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./protocol": {
        "types": "./dist/protocol.d.ts",
        "default": "./dist/protocol.js"
      },
      "./collector": {
        "types": "./dist/collector.d.ts",
        "default": "./dist/collector.js"
      },
      "./cosignals": {
        "types": "./dist/cosignals.d.ts",
        "default": "./dist/cosignals.js"
      },
      "./cosignals-arena": {
        "types": "./dist/cosignals-arena.d.ts",
        "default": "./dist/cosignals-arena.js"
      },
      "./panel": {
        "types": "./dist/panel/mount.d.ts",
        "default": "./dist/panel/mount.js"
      },
      "./button": {
        "types": "./dist/panel/DevtoolsPanelButton.d.ts",
        "default": "./dist/panel/DevtoolsPanelButton.js"
      },
      "./vite": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "./engine": {
        "types": "./dist/engine.d.ts",
        "default": "./dist/engine.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:extension": "node scripts/build-extension.mjs"
  },
  "dependencies": {
    "bippy": "^0.5.39"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/chrome": "^0.0.270",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "6.0.2",
    "cosignals": "workspace:*",
    "cosignals-arena": "workspace:*",
    "esbuild": "^0.28.0",
    "jsdom": "^26.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2",
    "vite": "8.1.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "cosignals": ">=0.1.0-0",
    "cosignals-arena": ">=0.1.0-0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "cosignals": {
      "optional": true
    },
    "cosignals-arena": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
