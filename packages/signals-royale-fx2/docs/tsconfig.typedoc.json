{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["react", "react-dom"]
	},
	"include": ["../src"]
}
