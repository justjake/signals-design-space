+/**
+ * Copyright (c) Meta Platforms, Inc. and affiliates.
+ *
+ * This source code is licensed under the MIT license found in the
+ * LICENSE file in the root directory of this source tree.
+ *
+ * @flow
+ */
+
+import ReactSharedInternals from './ReactSharedInternalsClient';
+
+function provider(): any {
+  const value = ReactSharedInternals.P;
+  if (value === null) {
+    throw new Error('This React renderer does not support Strata signals.');
+  }
+  return value;
+}
+
+export const strata = {
+  register(runtime: any): () => void {
+    if (ReactSharedInternals.R !== null && ReactSharedInternals.R !== runtime) {
+      throw new Error('A Strata runtime is already registered.');
+    }
+    ReactSharedInternals.R = runtime;
+    return () => {
+      if (ReactSharedInternals.R === runtime) {
+        if (ReactSharedInternals.P !== null) ReactSharedInternals.P.reset();
+        ReactSharedInternals.R = null;
+      }
+    };
+  },
+  write(fn: mixed): mixed {
+    return provider().write(fn);
+  },
+  run(lane: number, fn: () => mixed): mixed {
+    return provider().run(lane, fn);
+  },
+  urgent(fn: () => mixed): mixed {
+    return provider().urgent(fn);
+  },
+  current(): mixed {
+    return ReactSharedInternals.P === null
+      ? null
+      : ReactSharedInternals.P.current();
+  },
+};
