   stopCompletedGestures,
 } from './ReactFiberGestureScheduler';
 import {claimQueuedTransitionTypes} from './ReactFiberTransitionTypes';
-
 const PossiblyWeakMap = typeof WeakMap === 'function' ? WeakMap : Map;
 
+let signalUpdateLane: Lane = NoLane;
+let activeSignalRoot: FiberRoot | null = null;
+
+function runWithSignalLane(lane: Lane, fn: () => mixed): mixed {
+  const previous = signalUpdateLane;
+  signalUpdateLane = lane;
+  try {
+    return fn();
+  } finally {
+    signalUpdateLane = previous;
+  }
+}
+
+function prepareSignalPass(root: FiberRoot, lanes: Lanes): void {
+  const runtime = ReactSharedInternals.R;
+  if (runtime === null) return;
+  if (activeSignalRoot !== null) {
+    runtime.abort(activeSignalRoot, activeSignalRoot.pendingLanes);
+  }
+  runtime.begin(root, root.containerInfo, lanes, root.pendingLanes);
+  activeSignalRoot = root;
+}
+
+(ReactSharedInternals: any).P = {
+  write(fn: (Lane, boolean) => mixed): mixed {
+    if ((executionContext & RenderContext) !== NoContext) {
+      throw new Error('Signals cannot be written while React is rendering.');
+    }
+    const transition = requestCurrentTransition();
+    const lane =
+      signalUpdateLane !== NoLane
+        ? signalUpdateLane
+        : transition !== null
+          ? requestTransitionLane(transition)
+          : eventPriorityToLane(resolveUpdatePriority());
+    return runWithSignalLane(lane, () =>
+      fn(lane, includesTransitionLane(lane)),
+    );
+  },
+  run(lane: Lane, fn: () => mixed): mixed {
+    return runWithSignalLane(lane, fn);
+  },
+  urgent(fn: () => mixed): mixed {
+    return runWithSignalLane(eventPriorityToLane(resolveUpdatePriority()), fn);
+  },
+  current(): mixed {
+    const runtime = ReactSharedInternals.R;
+    return (executionContext & RenderContext) !== NoContext && runtime !== null
+      ? runtime.current()
+      : null;
+  },
+  reset(): void {
+    const runtime = ReactSharedInternals.R;
+    if (runtime !== null) runtime.reset();
+    activeSignalRoot = null;
+  },
+};
+
 type ExecutionContext = number;
 
 export const NoContext = /*             */ 0b000;
@@ -810,6 +867,8 @@ export function requestUpdateLane(fiber: Fiber): Lane {
     return pickArbitraryLane(workInProgressRootRenderLanes);
   }
 
+  if (signalUpdateLane !== NoLane) return signalUpdateLane;
+
   const transition = requestCurrentTransition();
   if (transition !== null) {
     if (enableGestureTransition) {
@@ -1930,6 +1989,7 @@ function finalizeRender(lanes: Lanes, finalizationTime: number): void {
 }
 
 function prepareFreshStack(root: FiberRoot, lanes: Lanes): Fiber {
+  prepareSignalPass(root, lanes);
   if (enableProfilerTimer && enableComponentPerformanceTrack) {
     // The order of tracks within a group are determined by the earliest start time.
     // Are tracks should show up in priority order and we should ideally always show
@@ -2665,6 +2725,10 @@ function renderRootSync(
   } else {
     // Normal case. We completed the whole tree.
 
+    const runtime = ReactSharedInternals.R;
+    if (runtime !== null) runtime.pause(root);
+    if (activeSignalRoot === root) activeSignalRoot = null;
+
     // Set this to null to indicate there's no in-progress render.
     workInProgressRoot = null;
     workInProgressRootRenderLanes = NoLanes;
@@ -2945,6 +3009,10 @@ function renderRootConcurrent(root: FiberRoot, lanes: Lanes): RootExitStatus {
     return RootInProgress;
   } else {
     // Completed the tree.
+
+    const runtime = ReactSharedInternals.R;
+    if (runtime !== null) runtime.pause(root);
+    if (activeSignalRoot === root) activeSignalRoot = null;
     if (enableSchedulingProfiler) {
       markRenderStopped();
     }
@@ -3852,6 +3920,9 @@ function flushMutationEffects(): void {
     setCurrentUpdatePriority(DiscreteEventPriority);
     const prevExecutionContext = executionContext;
     executionContext |= CommitContext;
+    const signalRuntime = ReactSharedInternals.R;
+    if (signalRuntime !== null)
+      signalRuntime.mutation(true, root.containerInfo);
     try {
       // The next phase is the mutation phase, where we mutate the host tree.
       commitMutationEffects(root, finishedWork, lanes);
@@ -3863,6 +3934,8 @@ function flushMutationEffects(): void {
       }
       resetAfterCommit(root.containerInfo);
     } finally {
+      if (signalRuntime !== null)
+        signalRuntime.mutation(false, root.containerInfo);
       // Reset the priority to the previous non-sync value.
       executionContext = prevExecutionContext;
       setCurrentUpdatePriority(previousPriority);
@@ -3875,6 +3948,10 @@ function flushMutationEffects(): void {
   // componentWillUnmount, but before the layout phase, so that the finished
   // work is current during componentDidMount/Update.
   root.current = finishedWork;
+  const signalRuntime = ReactSharedInternals.R;
+  if (signalRuntime !== null) {
+    signalRuntime.end(root, true, lanes, pendingEffectsRemainingLanes);
+  }
   pendingEffectsStatus = PENDING_LAYOUT_PHASE;
 }
 
