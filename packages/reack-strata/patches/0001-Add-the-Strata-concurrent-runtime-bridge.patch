diff --git a/packages/react-dom/src/__tests__/ReactStrata-test.js b/packages/react-dom/src/__tests__/ReactStrata-test.js
new file mode 100644
index 0000000000..b4f57bd758
--- /dev/null
+++ b/packages/react-dom/src/__tests__/ReactStrata-test.js
@@ -0,0 +1,172 @@
+/**
+ * Copyright (c) Meta Platforms, Inc. and affiliates.
+ *
+ * This source code is licensed under the MIT license found in the
+ * LICENSE file in the root directory of this source tree.
+ *
+ * @emails react-core
+ */
+
+'use strict';
+
+let React;
+let ReactDOMClient;
+let act;
+
+describe('React Strata bridge', () => {
+  beforeEach(() => {
+    jest.resetModules();
+    React = require('react');
+    ReactDOMClient = require('react-dom/client');
+    ({act} = require('internal-test-utils'));
+  });
+
+  it('reports render passes, root commits, and the exact mutation window', async () => {
+    const container = document.createElement('div');
+    const events = [];
+    let renderPass;
+    let currentPass;
+    const passes = new Map();
+    const runtime = {
+      begin(root, target, lanes) {
+        const pass = {target, lanes};
+        passes.set(root, pass);
+        currentPass = pass;
+        events.push(['begin', target, lanes]);
+      },
+      abort(root) {
+        passes.delete(root);
+        currentPass = undefined;
+      },
+      pause() {
+        currentPass = undefined;
+      },
+      end(root, committed, lanes, remaining) {
+        const pass = passes.get(root);
+        passes.delete(root);
+        events.push(['end', pass, committed, lanes, remaining]);
+      },
+      current() {
+        return currentPass;
+      },
+      reset() {
+        passes.clear();
+        currentPass = undefined;
+      },
+      mutation(active, target) {
+        events.push([
+          active ? 'mutation-start' : 'mutation-stop',
+          target,
+          container.textContent,
+        ]);
+      },
+    };
+    const unregister = React.unstable_strata.register(runtime);
+    function App() {
+      renderPass = React.unstable_strata.current();
+      return <span>ready</span>;
+    }
+
+    const root = ReactDOMClient.createRoot(container);
+    await act(() => root.render(<App />));
+    expect(renderPass.target).toBe(container);
+    expect(events[0][0]).toBe('begin');
+    expect(events[1]).toEqual(['mutation-start', container, '']);
+    expect(events[2]).toEqual(['mutation-stop', container, 'ready']);
+    expect(events[3][0]).toBe('end');
+    expect(events[3][1]).toBe(renderPass);
+    expect(events[3][2]).toBe(true);
+    expect(events[3][4]).toBe(0);
+
+    await act(() => root.unmount());
+    unregister();
+  });
+
+  it('pins signal notifications to their write lane and can escape a transition urgently', async () => {
+    const container = document.createElement('div');
+    const passes = [];
+    let currentPass;
+    const runtime = {
+      begin(_root, _target, lanes) {
+        passes.push(lanes);
+        currentPass = {};
+      },
+      abort() {},
+      pause() {
+        currentPass = undefined;
+      },
+      end() {},
+      current() {
+        return currentPass;
+      },
+      reset() {},
+      mutation() {},
+    };
+    const unregister = React.unstable_strata.register(runtime);
+    let setValue;
+    function App() {
+      const [value, set] = React.useState(0);
+      setValue = set;
+      return <span>{value}</span>;
+    }
+
+    const root = ReactDOMClient.createRoot(container);
+    await act(() => root.render(<App />));
+    let transitionLane;
+    await act(() => {
+      React.startTransition(() => {
+        React.unstable_strata.write((lane, deferred) => {
+          transitionLane = lane;
+          expect(deferred).toBe(true);
+          setValue(1);
+        });
+      });
+    });
+    expect(passes.some(lanes => (lanes & transitionLane) !== 0)).toBe(true);
+
+    const passCount = passes.length;
+    await act(() => {
+      React.startTransition(() => {
+        React.unstable_strata.urgent(() => setValue(2));
+      });
+    });
+    expect(container.textContent).toBe('2');
+    expect(
+      passes.slice(passCount).some(lanes => (lanes & transitionLane) === 0),
+    ).toBe(true);
+
+    await act(() => root.unmount());
+    unregister();
+  });
+
+  it('rejects writes during render', async () => {
+    const container = document.createElement('div');
+    const runtime = {
+      begin() {},
+      abort() {},
+      pause() {},
+      end() {},
+      current() {},
+      reset() {},
+      mutation() {},
+    };
+    const unregister = React.unstable_strata.register(runtime);
+    let error;
+    function Bad() {
+      try {
+        React.unstable_strata.write(() => {});
+      } catch (thrown) {
+        error = thrown;
+      }
+      return null;
+    }
+
+    const root = ReactDOMClient.createRoot(container);
+    await act(() => root.render(<Bad />));
+    expect(error.message).toContain(
+      'cannot be written while React is rendering',
+    );
+    await act(() => root.unmount());
+    unregister();
+  });
+});
diff --git a/packages/react-reconciler/src/ReactFiberWorkLoop.js b/packages/react-reconciler/src/ReactFiberWorkLoop.js
index 3de2ab6b16..1206e858c9 100644
--- a/packages/react-reconciler/src/ReactFiberWorkLoop.js
