{
  "name": "cosignals-arena",
  "version": "0.1.1",
  "description": "The data-oriented build version of cosignals: the same concurrent signals API for React, with the reactive graph stored in typed-array records instead of linked JS objects. Probably faster; definitely harder to read.",
  "keywords": [
    "async",
    "atom",
    "concurrent",
    "concurrent-rendering",
    "data-oriented",
    "hooks",
    "react",
    "reactive",
    "signals",
    "state",
    "state-management",
    "store",
    "suspense",
    "transitions",
    "typed-array"
  ],
  "homepage": "https://github.com/justjake/signals-design-space/tree/main/packages/cosignals-arena#readme",
  "bugs": "https://github.com/justjake/signals-design-space/issues",
  "license": "MIT",
  "author": "Jake Teton-Landis <just.1.jake@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justjake/signals-design-space.git",
    "directory": "packages/cosignals-arena"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "./src/index.ts",
    "./src/react/index.ts",
    "./dist/index.js",
    "./dist/react/index.js"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core.ts",
    "./ssr": "./src/ssr.ts",
    "./react": "./src/react/index.ts",
    "./debug": "./src/debug/index.ts",
    "./unstable": "./src/unstable.ts",
    "./testing": "./src/testing.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./core": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "./ssr": {
        "types": "./dist/ssr.d.ts",
        "default": "./dist/ssr.js"
      },
      "./react": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "./debug": {
        "types": "./dist/debug/index.d.ts",
        "default": "./dist/debug/index.js"
      },
      "./unstable": {
        "types": "./dist/unstable.d.ts",
        "default": "./dist/unstable.js"
      },
      "./testing": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:react18": "COSIGNALS_REACT=18 vitest run",
    "fuzz": "vitest run tests/oracle-fuzz.spec.ts",
    "bench": "node bench/react-bench.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^26.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "reactive-framework-test-suite": "0.0.2",
    "scheduler": "0.27.0",
    "typescript": "7.0.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "scheduler": ">=0.23.0"
  }
}
