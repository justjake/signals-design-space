{
  "name": "alien-signals-opt",
  "private": true,
  "type": "module",
  "scripts": {
    "conformance": "pnpm -C harness conformance",
    "inlining": "pnpm -C harness inlining",
    "bench": "pnpm -C harness bench",
    "memory": "pnpm -C harness memory",
    "typecheck": "pnpm -C harness typecheck",
    "fork:build": "fork/build-react.sh",
    "fork:test": "cd vendor/react && yarn test --no-watchman ReactFiberBatchRegistry",
    "play": "pnpm --filter react-signals-playground dev --open"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.0",
      "onFail": "download"
    }
  },
  "pnpm": {
    "overrides": {
      "react": "link:vendor/react/build/oss-experimental/react",
      "react-dom": "link:vendor/react/build/oss-experimental/react-dom",
      "scheduler": "link:vendor/react/build/oss-experimental/scheduler"
    }
  }
}
