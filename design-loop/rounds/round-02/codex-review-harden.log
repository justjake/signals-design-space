   537	  return entry.th                                            // identity stable (pure retry)
   538	else:
   539	  drop cache positions ≥ p for this (node, lineage)
   540	  store fresh entry {th: userThenable, prefixDeps: thisRun.depsSoFar, gen}
   541	  return userThenable                                        // new fetch, new identity — correct
