+
+let dispose: (() => void) | undefined;
+setAutomaticReclamation(false);
+const framework: ReactiveFramework<CellId> = {
+  name: "Royale SH2",
+  createSignal: atomId,
+  readSignal: read,
+  writeSignal: set,
+  createComputed: computedId,
+  readComputed: read,
+  effect(fn) {
+    effect(fn);
+  },
+  withBatch: batch,
+  withBuild<T>(fn: () => T): T {
+    let value!: T;
+    dispose = effectScope(() => {
+      value = fn();
+    });
+    return value;
+  },
+  cleanup() {
+    dispose?.();
+    dispose = undefined;
+    reset();
+  },
+};
+
+export default framework;
