+  // treated as cleanup functions and fn passes through unwrapped.
+  effect: (fn) => {
+    lib.effect(fn);
+  },
+  withBatch: (fn) => {
+    lib.startBatch();
+    fn();
+    lib.endBatch();
+  },
+  withBuild: <T>(fn: () => T) => {
+    let out!: T;
+    scope = lib.effectScope(() => {
+      out = fn();
+    });
+    return out;
+  },
+  cleanup: () => {
+    if (scope !== null) {
+      scope();
+      scope = null;
+    }
