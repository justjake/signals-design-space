  4272	/** Coalesce writes: one flush + one drain (one walk ticket) at close (§9.8). */
  4273	export function batch<T>(fn: () => T): T {
  4274		++batchDepth;
  4275		try {
  4276			return fn();
  4277		} finally {
  4278			if (--batchDepth === 0) {
  4279				E.flush();
  4280				E.drainAll();
  4281				boundary();
  4282			}
  4283		}
  4284	}
  4285	
  4286	/** Low-level batch surface (adapter/bindings plumbing; prefer batch()). */
  4287	export function startBatch(): void {
  4288		++batchDepth;
  4289	}
  4290	
  4291	export function endBatch(): void {
  4292		if (--batchDepth === 0) {
  4293			E.flush();
  4294			E.drainAll();
  4295			boundary();
  4296		}
  4297	}
  4298	
  4299	export function untracked<T>(fn: () => T): T {
  4300		const prevSub = activeSub;
  4301		activeSub = 0;
  4302		try {
  4303			return fn();
  4304		} finally {
  4305			activeSub = prevSub;
  4306		}
  4307	}
