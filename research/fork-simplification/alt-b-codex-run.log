   317	describe('Solid-2.0 async API set against real React (§2/§7, solid2-async-model)', () => {
   318		/** Resource idiom: one promise per (param, refreshEpoch) request key. */
   319		function makeResource() {
   320			const param = new Atom({ state: 1 });
   321			const gates = new Map<string, { promise: Promise<string>; resolve: (v: string) => void }>();
   322			function gateFor(key: string) {
   323				let g = gates.get(key);
   324				if (g === undefined) {
   325					let resolve!: (v: string) => void;
   326					const promise = new Promise<string>((res) => {
   327						resolve = res;
   328					});
   329					g = { promise, resolve };
   330					gates.set(key, g);
   331				}
   332				return g;
   333			}
   334			const data = new Computed<string>({
   335				fn: (ctx) => ctx.use(gateFor(`${param.state}:${ctx.refreshEpoch}`).promise),
   336			});
   337			return { param, data, gateFor };
   338		}
   339	
   340		async function settleKey(r: ReturnType<typeof makeResource>, key: string, v: string) {
   341			await act(async () => {
   342				r.gateFor(key).resolve(v);
   343				await r.gateFor(key).promise;
   344				await Promise.resolve();
   345			});
   346		}
