   525						this.emit((l) => l.onRenderPassEnd?.(container));
   526					},
   527					onBatchRetired: (token, committed) => {
   528						this.live.delete(token);
   529						this.emit((l) => l.onBatchRetired?.(token, committed));
   530					},
   531					onRootCommitted: (container, committedBatches) => {
   532						for (const token of committedBatches) {
   533							this.emit((l) => l.onBatchCommitted?.(container, token));
   534						}
   535					},
   536					onBeforeMutation: (container) => this.emit((l) => l.onBeforeMutation?.(container)),
   537					onAfterMutation: (container) => this.emit((l) => l.onAfterMutation?.(container)),
   538				}),
   539			);
   540		}
   541	
   542		private emit(fn: (l: ExternalRuntimeListener) => void): void {
   543			for (const l of this.listeners) {
   544				fn(l);
   545			}
   546		}
   547	
   548		subscribeToExternalRuntime(l: ExternalRuntimeListener): () => void {
   549			this.listeners.add(l);
   550			return () => {
   551				this.listeners.delete(l);
   552			};
   553		}
   554	
   555		isCurrentWriteDeferred(): boolean {
   556			return (this.R.unstable_getCurrentWriteBatch() & 1) === 1;
   557		}
   558	
   559		/** The transition-scope object whose batch we last minted, for the
   560		 * read-your-own-draft probe (ambient-W0 semantics). */
   561		private lastScopeT: unknown = null;
   562		private lastScopeToken = 0;
   563	
   564		private currentTransitionScope(): unknown {
   565			const internals = (
   566				this.R as unknown as {
   567					__CLIENT_INTERNALS_DO_NOT_USE_OR_WARN_USERS_THEY_CANNOT_UPGRADE?: { T?: unknown };
   568				}
   569			).__CLIENT_INTERNALS_DO_NOT_USE_OR_WARN_USERS_THEY_CANNOT_UPGRADE;
   570			return internals?.T ?? null;
   571		}
   572	
   573		getCurrentWriteBatch(): number {
   574			const token = this.R.unstable_getCurrentWriteBatch();
   575			// Remember (T → token) so ambient reads later in the SAME synchronous
   576			// transition scope resolve that batch's world (read-your-own-draft).
   577			if ((token & 1) === 1) {
   578				const t = this.currentTransitionScope();
   579				if (t !== null) {
   580					this.lastScopeT = t;
   581					this.lastScopeToken = token;
   582				}
   583			}
   584			return token;
   585		}
   586	
   587		/** Ambient-W0 semantics (SPEC-RESOLUTIONS §ambient-W0): the deferred
   588		 * batch whose write scope is executing NOW, or 0. Identity-keyed on the
   589		 * reconciler's current-transition slot: minted at the scope's first
   590		 * write; reads before any write correctly see W0 (no draft exists). A
   591		 * different transition or plain handler has a different (or null) T. */
   592		getAmbientReadToken(): number {
   593			if (this.lastScopeToken === 0) {
   594				return 0;
   595			}
   596			const t = this.currentTransitionScope();
   597			return t !== null && t === this.lastScopeT ? this.lastScopeToken : 0;
   598		}
   599	
   600		getRenderContext(): { container: Container } | undefined {
   601			return this.R.unstable_getRenderContext() ?? undefined;
   602		}
   603	
   604		runInBatch(token: number, fn: () => void): boolean {
   605			let ran = false;
   606			try {
   607				ran = this.R.unstable_runInBatch(token, fn) !== false;
   608			} catch {
   609				ran = false; // e.g. called during render: fall back to urgent (§6.5)
   610			}
   611			this.entangleLog.push({ token, ran });
   612			return ran;
   613		}
   614	
   615		liveTokens(): number[] {
   616			return [...this.live.keys()];
   617		}
   618	
   619		isBatchLive(token: number): boolean {
   620			return this.live.has(token);
   621		}
   622	
   623		isQuiescent(): boolean {
   624			return this.live.size === 0 && this.passContainer === undefined;
   625		}
   626	
   627		hasOpenWork(): boolean {
   628			if (this.live.size !== 0 || this.passContainer !== undefined) {
   629				return true;
   630			}
   631			// An open transition scope whose batch is not minted yet (protocol v2
   632			// mints lazily): the reconciler's current-transition slot is the only
   633			// pre-mint witness. Reading it through the shared-internals export is
   634			// the sound alternative to patching a pure classification API in.
   635			const internals = (
   636				this.R as unknown as {
   637					__CLIENT_INTERNALS_DO_NOT_USE_OR_WARN_USERS_THEY_CANNOT_UPGRADE?: { T?: unknown };
   638				}
   639			).__CLIENT_INTERNALS_DO_NOT_USE_OR_WARN_USERS_THEY_CANNOT_UPGRADE;
   640			if (internals !== undefined && internals.T !== null && internals.T !== undefined) {
   641				return true;
   642			}
   643			return this.R.unstable_getRenderContext() !== null;
   644		}
   645	
   646		startTransition(scope: () => void): number {
   647			let token = 0;
   648			this.R.startTransition(() => {
   649				scope();
   650				token = this.R.unstable_getCurrentWriteBatch(); // mints the transition batch
   651			});
   652			return token;
   653		}
   654	
   655		dispose(): void {
   656			for (const u of this.unsubs) {
   657				u();
   658			}
   659			this.unsubs.length = 0;
   660			this.listeners.clear();
   661			this.live.clear();
   662		}
   663	}
