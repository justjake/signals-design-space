  4309	/** §13.6 — startTransition + engine batch(): N writes in the scope coalesce
  4310	 * to one notify walk and one drain. Returns the batch token (double-driven).
  4311	 * Not required for correctness — a throughput helper. */
  4312	export function startSignalTransition(scope: () => void): number {
  4313		const f = fork;
  4314		if (f === undefined) {
  4315			throw new Error('cosignals-alt-b: startSignalTransition requires an attached fork');
  4316		}
  4317		let token = 0;
  4318		batch(() => {
  4319			token = f.startTransition(scope);
  4320		});
  4321		return token;
  4322	}
