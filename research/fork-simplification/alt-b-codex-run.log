   443	//   protocol opens a pass while another container's is open (defensive —
   444	//   the host closes frames before restarting), the stale frame is ended
   445	//   first, matching the shim precedent in cosignals-react.
   446	// ============================================================================
   447	
   448	type ReactRuntime = {
   449		unstable_registerBatchIdAllocator(fn: (deferred: boolean) => number): () => void;
   450		unstable_subscribeToExternalRuntime(l: {
   451			onRenderPassStart?: (container: unknown, includedBatches: readonly number[]) => void;
   452			onRenderPassYield?: (container: unknown) => void;
   453			onRenderPassResume?: (container: unknown) => void;
   454			onRenderPassEnd?: (container: unknown, committed: boolean) => void;
   455			onBatchRetired?: (batchId: number, committed: boolean) => void;
   456			onRootCommitted?: (
   457				container: unknown,
   458				committedBatches: readonly number[],
   459				generation: number,
   460			) => void;
   461			onBeforeMutation?: (container: unknown) => void;
   462			onAfterMutation?: (container: unknown) => void;
   463		}): () => void;
   464		unstable_getCurrentWriteBatch(): number;
   465		unstable_getRenderContext(): { container: unknown } | null;
   466		unstable_runInBatch(batchId: number, fn: () => void): boolean;
   467		unstable_resetBatchRegistryForTest?(): void;
   468		startTransition(scope: () => void): void;
   469	};
