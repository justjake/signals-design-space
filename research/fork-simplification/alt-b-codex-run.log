   438		async function useAlignment(strict: boolean) {
   439			configure({ strictLanes: strict });
   440			try {
   441				// Rule (a) alignment: a signals consumer (useSignal → node-held
   442				// box → React use()) and a DIRECT React.use() consumer of the
   443				// SAME promise must land in the SAME transition commit — never a
   444				// frame with one side new and the other old.
   445				const gate = deferred<string>();
   446				const flag = new Atom({ state: false });
   447				const sig = new Computed<string>({
   448					fn: (ctx) => (flag.state ? ctx.use(gate.promise) : 'off'),
   449				});
   450				function SignalSide() {
   451					return <span>s:{useSignal(sig)}</span>;
   452				}
   453				function UseSide({ go }: { go: boolean }) {
   454					return <b>u:{go ? React.use(gate.promise) : 'off'}</b>;
   455				}
   456				const commits: string[] = [];
   457				let target: HTMLElement | null = null;
   458				function Recorder() {
   459					React.useLayoutEffect(() => {
   460						commits.push(target?.textContent ?? '');
   461					});
   462					return null;
   463				}
   464				let setGo!: (b: boolean) => void;
   465				function App() {
   466					const [go, set] = React.useState(false);
   467					setGo = set;
   468					return (
   469						<React.Suspense fallback={<i>loading</i>}>
   470							<SignalSide />
   471							<UseSide go={go} />
   472							<Recorder />
   473						</React.Suspense>
   474					);
   475				}
   476				const el = await mount(<App />);
   477				target = el;
   478				expect(el.textContent).toBe('s:offu:off');
   479				await act(async () => {
   480					React.startTransition(() => {
   481						flag.set(true); // sig → refresh-pending (latest 'off') on gate.promise
   482						setGo(true); // UseSide → React.use(gate.promise)
   483					});
   484				});
   485				// Both sides suspended INSIDE the transition: held, no fallback,
   486				// no early commit — the old frame stays.
   487				expect(el.textContent).toBe('s:offu:off');
   488				await act(async () => {
   489					gate.resolve('DATA');
   490					await gate.promise;
   491				});
   492				expect(el.textContent).toBe('s:DATAu:DATA');
   493				// The no-tearing assertion: every committed frame is fully-old or
   494				// fully-new; the two waiters of one promise never split a commit.
   495				// (The mount commit records '' — the target ref is assigned after
   496				// mount returns; only real frames are checked.)
   497				for (const frame of commits.filter((f) => f !== '')) {
   498					const oldFrame = frame.includes('s:off') && frame.includes('u:off');
   499					const newFrame = frame.includes('s:DATA') && frame.includes('u:DATA');
   500					expect(oldFrame || newFrame).toBe(true);
   501				}
   502			} finally {
   503				configure({ strictLanes: false });
   504			}
   505		}
