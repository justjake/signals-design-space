     1	#!/usr/bin/env bash
     2	# Build the patched React (vendor/react) packages our workspace consumes.
     3	# (Ported from react-signals-fable scripts/build-react.sh; see fork/README.md.)
     4	#
     5	# Uses scripts/rollup/build.js directly (~13s for our bundle set) rather than
     6	# `yarn build` (build-all-release-channels.js), which builds every channel for
     7	# minutes and overwrites packages/shared/ReactVersion.js with a placeholder.
     8	#
     9	# Artifacts land in vendor/react/build/oss-experimental/{react,react-dom,scheduler}.
    10	# The workspace consumes them via `link:` overrides in the root package.json, so
    11	# a rebuild is picked up without re-running pnpm install.
    12	#
    13	# The built react-dom resolves `scheduler`/`react` by walking up its real path
    14	# into vendor/react/node_modules, where yarn links point at *source* packages;
    15	# the node_modules dir of symlinks created below fixes resolution.
    16	set -euo pipefail
    17	
    18	cd "$(dirname "$0")/../vendor/react"
    19	
    20	ENTRIES="react/index,react/jsx,react/compiler-runtime,react-dom/index,react-dom/client,react-dom/test-utils,scheduler"
    21	
    22	# Locally, pin the node version React's own CI uses (.nvmrc) via mise; in CI
    23	# (or anywhere without mise) use whatever node is on PATH.
    24	if command -v mise >/dev/null 2>&1; then
    25	  NODE_RUNNER=(mise exec "node@$(tr -d 'v[:space:]' <.nvmrc)" -- node)
    26	else
    27	  NODE_RUNNER=(node)
    28	fi
    29	
    30	RELEASE_CHANNEL=experimental "${NODE_RUNNER[@]}" \
    31	  ./scripts/rollup/build.js "$ENTRIES" --type=NODE_DEV,NODE_PROD
    32	
    33	rm -rf build/oss-experimental
    34	mv build/node_modules build/oss-experimental
    35	
    36	cd build/oss-experimental
    37	mkdir -p node_modules
    38	for pkg in react react-dom scheduler; do
    39	  ln -sfn "../$pkg" "node_modules/$pkg"
    40	done
    41	
    42	echo "Built: $(node -p "require('./react/package.json').version") ($(git -C ../.. rev-parse --short HEAD))"

