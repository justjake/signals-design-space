   148				this.ambientToken = this.openBatch(false);
   149			}
   150			return this.ambientToken;
   151		}
   152	
   153		/** §6.1 — defined only while React is *executing* render code. The double
   154		 * mirrors that: undefined inside yield gaps. */
   155		getRenderContext(): { container: Container } | undefined {
   156			if (this.pass !== undefined && !this.pass.yielded) {
   157				return { container: this.pass.container };
   158			}
   159			return undefined;
   160		}
   161	
   162		/** §6.5 — batch entanglement. Token live: run fn in that batch's context
   163		 * (write classification included) and return true. Retired: return false
   164		 * without running fn. Nesting uses the innermost override. */
   165		runInBatch(token: number, fn: () => void): boolean {
   166			const b = this.batches.get(token);
   167			if (b === undefined || b.retired) {
   168				this.entangleLog.push({ token, ran: false });
   169				return false;
   170			}
   171			this.entangleLog.push({ token, ran: true });
   172			this.contextStack.push(token);
   173			try {
   174				fn();
   175			} finally {
   176				this.contextStack.pop();
   177			}
   178			return true;
   179		}
   180	
   181		// ---- scripting surface -----------------------------------------------------
   182	
   183		/** Claim + mint a batch token (§6.2). Emits the onBatchOpened gate edge. */
   184		openBatch(deferred: boolean): number {
   185			if (this.live.size >= this.maxLiveTokens) {
   186				throw new Error(
   187					`ForkDouble: ${this.live.size} live tokens; §6.2 caps at ${this.maxLiveTokens}`,
   188				);
   189			}
   190			const token = ((++this.serial) << 1) | (deferred ? 1 : 0);
