  4332	
  4333	/**
  4334	 * A watcher node (kind K_WATCHER, WATCHING|IMMEDIATE): notified synchronously
  4335	 * in the writer's stack via the broadcast list, with the §10.6 world-value
  4336	 * cutoff. `cb(token)` simulates the hook's setState; deferred tokens arrive
  4337	 * inside the fork's runInBatch scope (assert via the double's entangleLog).
  4338	 * Subscription seeds lastBroadcast per live deferred world (the engine-level
  4339	 * analogue of §13.2's post-subscribe fixup) and registers the memos that make
  4340	 * slot-chain re-validation complete for late subscribers.
  4341	 */
  4342	export function createWatcher(signal: SignalLike, cb: (token: number) => void): WatcherHandle {
  4343		boundary();
  4344		const h = E.makeWatcher(signal.id, cb);
  4345		return {
  4346			id: h.id,
  4347			dispose() {
  4348				if (E.gen(h.id) !== h.gen) {
  4349					return;
  4350				}
  4351				E.dispose(h.id);
  4352				reclaimBoundary();
  4353				boundary();
  4354			},
  4355		};
  4356	}
