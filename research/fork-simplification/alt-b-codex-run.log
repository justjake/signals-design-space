   946	}
   947	
   948	/**
   949	 * §13.6 — useTransition + engine batching: writes in `scope` classify into
   950	 * the transition's batch and broadcast once per watcher.
   951	 */
   952	export function useSignalTransition(): [boolean, (scope: () => void) => void] {
   953		const [isPending, start] = ReactNS.useTransition();
   954		const startScoped = ReactNS.useCallback((scope: () => void) => {
   955			start(() => {
   956				batch(scope);
   957			});
   958		}, [start]);
   959		return [isPending, startScoped];
   960	}
     1	/**
     2	 * M0 — the React-fork test double.
     3	 *
     4	 * Implements the spec §6 external-runtime protocol surface exactly (the real
     5	 * fork lives elsewhere in this repo); adds a scripting surface so tests can
     6	 * simulate batch open/close, render passes with yield/resume, restarts,
     7	 * lineage, per-root commits, and retirement — all synchronously and
     8	 * deterministically.
     9	 *
    10	 * Protocol facts the double enforces (per §6.2/§6.3):
    11	 * - tokens: `(serial << 1) | deferredBit`, nonzero, never reused while live;
    12	 *   at most 31 live at once (throws beyond — the engine's slot-exhaustion
    13	 *   fallback is unit-tested by lifting this cap via `maxLiveTokens`).
    14	 * - exactly one retirement per token, ever.
    15	 * - one pass at a time; yield/resume strictly alternate between one start and
    16	 *   its end; a restart is end + start with the SAME lineage.
    17	 * - onBatchCommitted fires at most once per (token, container), and before
    18	 *   onBatchRetired when it is the token's last pending root.
    19	 *
    20	 * One deliberate protocol addition beyond §6.1 (reported as such): the
    21	 * listener may carry `onBatchOpened(token)`. §9.1 requires the DIRECT→LOGGED
    22	 * gate flip to ride a fork-signaled edge that precedes any write the batch
    23	 * could affect; in the real fork that edge is the registry's claim/mint edge
    24	 * (§6.2), which §6.1 does not surface as a callback. The double surfaces it
    25	 * so the bridge can flip the gate edge-triggered, never sampled.
    26	 */
    27	
    28	export type Container = unknown;
    29	
    30	/**
    31	 * The structural fork surface the engine and bindings consume (§6). Two
    32	 * implementations: ForkDouble (this file — the scriptable test double) and
    33	 * ReactFork (src/react.ts — the adapter over the actual patched React's
    34	 * external-runtime protocol).
    35	 */
    36	export type ForkLike = {
    37		subscribeToExternalRuntime(l: ExternalRuntimeListener): () => void;
    38		isCurrentWriteDeferred(): boolean;
    39		getCurrentWriteBatch(): number;
    40		getRenderContext(): { container: Container } | undefined;
    41		runInBatch(token: number, fn: () => void): boolean;
    42		liveTokens(): number[];
    43		isBatchLive(token: number): boolean;
    44		isQuiescent(): boolean;
    45		/**
    46		 * Is any React work open or pending RIGHT NOW — including a transition
    47		 * scope whose batch has not been minted yet (protocol v2 mints lazily at
    48		 * the first getCurrentWriteBatch call)? This is the §9.1 DIRECT→LOGGED
    49		 * gate's per-write probe: the batch-open edge alone cannot precede the
    50		 * first write of a fresh transition under lazy minting.
    51		 */
    52		hasOpenWork(): boolean;
    53		/**
    54		 * AMBIENT-W0 SEMANTICS (SPEC-RESOLUTIONS §ambient-W0): the deferred batch
    55		 * token whose WRITE SCOPE is executing synchronously right now, or 0.
    56		 * Ambient engine reads consult this for read-your-own-draft; outside any
    57		 * scope, ambient reads resolve W0 (drafts invisible until commit).
    58		 */
    59		getAmbientReadToken?(): number;
    60		/** startTransition + token capture (throughput helpers, §13.6). */
    61		startTransition(scope: () => void): number;
    62	};
    63	
    64	export type ExternalRuntimeListener = {
    65		onRenderPassStart?: (
    66			container: Container,
    67			includedBatches: readonly number[],
    68			lineage: number,
    69		) => void;
    70		onRenderPassEnd?: (container: Container) => void;
    71		onRenderPassYield?: (container: Container) => void;
    72		onRenderPassResume?: (container: Container) => void;
    73		onBatchCommitted?: (container: Container, token: number) => void;
    74		onBatchRetired?: (token: number, committed: boolean) => void;
    75		onBeforeMutation?: (container: Container) => void;
    76		onAfterMutation?: (container: Container) => void;
    77		/** Double extension (see module doc): the claim/mint edge of §6.2. */
    78		onBatchOpened?: (token: number) => void;
    79	};
    80	
    81	type BatchState = {
    82		token: number;
    83		deferred: boolean;
    84		retired: boolean;
    85		/** containers this token has committed on (per-root commit, §6.2 finish edge) */
