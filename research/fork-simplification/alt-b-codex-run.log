   101	
   102	export class ForkDouble {
   103		private listeners = new Set<ExternalRuntimeListener>();
   104		private serial = 0;
   105		private lineageSerial = 0;
   106		private batches = new Map<number, BatchState>();
   107		/** Live (unretired) tokens — O(1) liveness bookkeeping so long sessions
   108		 * do not degrade quadratically scanning every batch ever created. */
   109		private live = new Set<number>();
   110		/** Batch context stack for write attribution (innermost wins, §6.5). */
   111		private contextStack: number[] = [];
   112		/** Lazily-minted urgent token for writes outside any scripted batch. */
   113		private ambientToken = 0;
   114		private pass: PassState | undefined;
   115		/** Record of every runInBatch call, for test assertions. */
   116		readonly entangleLog: EntangleRecord[] = [];
   117		/** Cap on live tokens; §6.2 invariant is 31. Tests may raise it to force
   118		 * the engine's slot-exhaustion fallback. */
   119		maxLiveTokens = 31;
   120	
   121		// ---- §6.1 isomorphic API -------------------------------------------------
   122	
   123		subscribeToExternalRuntime(l: ExternalRuntimeListener): () => void {
   124			this.listeners.add(l);
   125			return () => {
   126				this.listeners.delete(l);
   127			};
   128		}
   129	
   130		/** §6.4 — pure classification of a write issued right now. */
   131		isCurrentWriteDeferred(): boolean {
   132			const token = this.currentContextToken();
   133			if (token !== 0) {
   134				return (token & 1) === 1;
   135			}
   136			return false;
   137		}
   138	
   139		/** §6.1 — token of the batch a write issued right now belongs to, minting
   140		 * lazily. The double mints an ambient urgent token when no scripted batch
   141		 * context is live (the real fork's per-event batch). */
   142		getCurrentWriteBatch(): number {
   143			const token = this.currentContextToken();
   144			if (token !== 0) {
   145				return token;
   146			}
