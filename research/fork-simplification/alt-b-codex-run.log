   665	// ---- activation + hooks (§4.5/§13) ---------------------------------------------
   666	
   667	import * as ReactNS from 'react';
   668	import { attachFork, detachFork } from './engine';
   669	import type { AtomOptions as AtomOpts, ReducerAtomOptions as ReducerOpts } from './engine';
   670	
   671	let activeFork: ReactFork | undefined;
   672	let activeBindings: ReactBindings | undefined;
   673	
   674	export type AltBReactHandle = {
   675		fork: ReactFork;
   676		bindings: ReactBindings;
   677		dispose(): void;
   678	};
   679	
   680	/**
   681	 * Couples the module-singleton engine to the patched React build. Call after
   682	 * importing react-dom/client (the renderer registers the protocol provider
   683	 * at module init) and before rendering any root. Throws on stock React.
   684	 * There is no required provider component (§4.5).
   685	 */
   686	export function registerAltBReact(): AltBReactHandle {
   687		if (activeFork !== undefined) {
   688			throw new Error('cosignals-alt-b/react: already registered (dispose the previous handle first)');
   689		}
   690		const fork = new ReactFork(ReactNS as unknown as ReactRuntime);
   691		attachFork(fork);
   692		const bindings = createReactBindings(fork);
   693		activeFork = fork;
   694		activeBindings = bindings;
   695		return {
   696			fork,
   697			bindings,
   698			dispose() {
   699				bindings.dispose();
   700				fork.dispose();
   701				detachFork();
   702				if (activeFork === fork) {
   703					activeFork = undefined;
   704					activeBindings = undefined;
   705				}
   706			},
   707		};
   708	}
   709	
   710	function requireBindings(): ReactBindings {
   711		if (activeBindings === undefined) {
   712			throw new Error('cosignals-alt-b/react: registerAltBReact() must run before using hooks');
   713		}
   714		return activeBindings;
   715	}
   716	
   717	type AnySignalHook = ReturnType<ReactBindings['mountSignal']>;
   718	
   719	/**
   720	 * §13.2 — subscribe this component to a signal; returns its value for the
   721	 * current render's world. Concurrent-safe: render reads resolve the pass's
   722	 * world; the layout-effect commit creates the watcher and runs the
   723	 * world-aware post-subscribe fixup (corrections entangled into pending
   724	 * batches' own lanes). Suspends while the value is a SuspendedBox.
   725	 */
   726	/** Shared hook body: mount/subscribe + render-read RAW (boxes included). */
   727	function useSignalRaw(signal: SignalLike & { state: unknown }): unknown {
   728		const b = requireBindings();
   729		const [, bump] = ReactNS.useReducer((c: number) => (c + 1) | 0, 0);
   730		const ref = ReactNS.useRef<{ hook: AnySignalHook; of: SignalLike } | null>(null);
   731		if (ref.current === null || ref.current.of !== signal) {
   732			ref.current?.hook.unmount();
   733			ref.current = {
   734				hook: b.mountSignal(signal, () => bump()) as AnySignalHook,
   735				of: signal,
   736			};
   737		}
   738		const value: unknown = ref.current.hook.renderRead();
   739		ReactNS.useLayoutEffect(() => {
   740			// Every commit: idempotent watcher creation + the §13.2 fixup for
   741			// writes that raced into the render→commit gap. StrictMode's
   742			// simulated unmount disposes the watcher; this recreates it.
   743			ref.current?.hook.commit();
   744		});
   745		ReactNS.useLayoutEffect(() => {
   746			return () => {
   747				ref.current?.hook.unmount();
   748			};
   749		}, []);
   750		return value;
   751	}
   752	
   753	export function useSignal<T>(signal: SignalLike & { state: T }): T {
   754		const value: unknown = useSignalRaw(signal);
   755		if (isErrorBox(value)) {
   756			throw value.error;
   757		}
   758		if (isSuspendedBox(value)) {
   759			// TWO-LEVEL SUSPENSE RULE, CONTEXT-SENSITIVE (solid2-async-model §2,
   760			// amended): (a) inside a TRANSITION pass, ALWAYS hand the thenable to
   761			// React use() — React natively holds old UI for suspends-in-
   762			// transition (no fallback flash) and keeps the transition pending
   763			// until settlement, so signals-side and React-side waiters of the
   764			// same promise land in ONE commit (no early commit with stale data);
   765			// (b) in an urgent/sync pass with a settled history, serve latest
   766			// through (suspending here would flash the fallback) — pending
   767			// surfaces via useIsPending; (c) never-settled always suspends.
   768			// Per-site opt-outs: latest() / isPending(). The engine never holds
   769			// transitions itself — React is the single waiter.
   770			const inTransitionPass = requireBindings().renderingDeferredPass();
   771			if (value.latest !== undefined && !inTransitionPass) {
   772				return value.latest as T; // (b) urgent stale-through
   773			}
   774			// (a)/(c): hand the NODE-HELD thenable to React use(): its identity
   775			// is store-stable across retries (foldEvalResult preserves the box
   776			// while the thenable is unchanged), so React resumes instead of
   777			// looping. use() is exempt from hook-order rules, so the conditional
   778			// call is legal.
   779			const use = (ReactNS as { use?: (t: PromiseLike<unknown>) => unknown }).use;
   780			if (use === undefined) {
   781				throw value.thenable; // pre-use() React: classic thrown-thenable suspend
   782			}
   783			use(value.thenable);
   784			// use() returned without suspending: the thenable already settled and
   785			// the engine's settlement write (registered first) has landed —
   786			// re-read (raw, ambient render context) for the post-settlement value.
   787			const again: unknown = readById(signal.id);
   788			if (isErrorBox(again)) {
   789				throw again.error;
   790			}
   791			if (isSuspendedBox(again)) {
   792				if (again.latest !== undefined && !inTransitionPass) {
   793					return again.latest as T; // re-pending on a NEW fetch: urgent stale-through
   794				}
   795				throw again.thenable; // still pending in this context: classic suspend
   796			}
   797			return again as T;
   798		}
   799		return value as T;
   800	}
   801	
   802	/** §7 isPending as a hook: reactive "stale data while newer loads" boolean.
   803	 * Flip-only re-renders — the probe computed's boolean equality suppresses
   804	 * upstream value churn; first load and errors read false. */
   805	export function useIsPending(signal: SignalLike): boolean {
   806		return useSignal(pendingComputedOf(signal));
   807	}
   808	
   809	/** §ambient-W0 companion hook: subscribe like useSignal but read the
   810	 * COMMITTED world (global committed view — the hook does not know its root;
   811	 * per-root refinement is the kernel-side effects' job via withRootCommitted).
   812	 * Never suspends: pending unwraps to box.latest (undefined while the
   813	 * committed world never had a value), errors rethrow. */
   814	export function useCommitted<T>(signal: SignalLike & { state: T }): T | undefined {
   815		useSignalRaw(signal); // subscription: re-render on broadcasts
   816		const raw = __debug.readInWorld(signal, { kind: 'committed' });
   817		if (isErrorBox(raw)) {
   818			throw raw.error;
   819		}
   820		if (isSuspendedBox(raw)) {
   821			return raw.latest as T | undefined;
   822		}
   823		return raw as T;
   824	}
   825	
   826	/** §7 latest as a hook: subscribe like useSignal but NEVER suspend — pending
   827	 * unwraps to box.latest (undefined while uninitialized), errors rethrow.
   828	 * World choice follows the render pass like useSignal (purity/replay). */
   829	export function useLatest<T>(signal: SignalLike & { state: T }): T | undefined {
   830		const raw = useSignalRaw(signal);
   831		if (isErrorBox(raw)) {
   832			throw raw.error;
   833		}
   834		if (isSuspendedBox(raw)) {
   835			return raw.latest as T | undefined;
   836		}
   837		return raw as T;
   838	}
   839	
   840	/** Holder pattern (§13.5): component-owned nodes survive StrictMode's
   841	 * simulated unmount by re-creating on the post-remount effect. */
   842	function useOwned<H extends SignalLike>(make: () => H): H {
   843		const [holder, setHolder] = ReactNS.useState(() => ({ node: make(), disposed: false }));
   844		ReactNS.useEffect(() => {
   845			if (holder.disposed) {
   846				setHolder({ node: make(), disposed: false });
   847				return;
   848			}
   849			return () => {
   850				holder.disposed = true;
   851				disposeSignal(holder.node);
   852			};
   853			// eslint-disable-next-line react-hooks/exhaustive-deps
   854		}, [holder]);
   855		return holder.node;
   856	}
   857	
   858	/** §13.5 — component-owned atom; like useState but a signal. */
   859	export function useAtom<T>(options: AtomOpts<T>): Atom<T> {
   860		const optionsRef = ReactNS.useRef(options);
   861		return useOwned(() => new Atom(optionsRef.current));
   862	}
   863	
   864	/** §13.5 — component-owned reducer atom; like useReducer. */
   865	export function useReducerAtom<S, A>(options: ReducerOpts<S, A>): ReducerAtom<S, A> {
   866		const optionsRef = ReactNS.useRef(options);
   867		return useOwned(() => new ReducerAtom(optionsRef.current));
   868	}
   869	
   870	function depsEqual(a: readonly unknown[], b: readonly unknown[]): boolean {
   871		if (a.length !== b.length) {
   872			return false;
   873		}
   874		for (let i = 0; i < a.length; ++i) {
   875			if (!Object.is(a[i], b[i])) {
   876				return false;
   877			}
   878		}
   879		return true;
   880	}
   881	
   882	/**
   883	 * §13.3 — like useMemo, but re-renders when a signal read inside `fn`
   884	 * changes. `fn` closes over props/state freely (that is what `deps` is for);
   885	 * signal reads are auto-tracked and NOT listed in deps. Node creation during
   886	 * render is engine-side allocation only; superseded nodes are disposed in an
   887	 * effect (a discarded render's node falls to FinalizationRegistry/reset).
   888	 */
   889	export function useComputed<T>(
   890		fn: () => T,
   891		deps: readonly unknown[],
   892		options?: { isEqual?: (a: T, b: T) => boolean; label?: string },
   893	): T {
   894		const ref = ReactNS.useRef<{ c: Computed<T>; deps: readonly unknown[]; retired: Computed<T>[] } | null>(null);
   895		if (ref.current === null || !depsEqual(ref.current.deps, deps)) {
   896			const retired = ref.current === null ? [] : [...ref.current.retired, ref.current.c];
   897			ref.current = {
   898				c: new Computed<T>({ fn: () => fn(), isEqual: options?.isEqual, label: options?.label }),
   899				deps,
   900				retired,
   901			};
   902		}
   903		const holder = ref.current;
   904		ReactNS.useEffect(() => {
   905			if (holder.retired.length !== 0) {
   906				for (const c of holder.retired) {
   907					disposeSignal(c);
   908				}
   909				holder.retired.length = 0;
   910			}
   911		});
   912		ReactNS.useEffect(() => {
   913			return () => {
   914				if (ref.current !== null) {
   915					disposeSignal(ref.current.c);
   916					ref.current = null;
   917				}
   918			};
   919		}, []);
   920		return useSignal(holder.c as SignalLike & { state: T });
   921	}
   922	
   923	/**
   924	 * §13.4 — like useEffect, but also re-runs when a tracked signal's committed
   925	 * value (per this component's root) changes. Cleanup supported.
   926	 */
   927	export function useSignalEffect(fn: () => void | (() => void), deps?: readonly unknown[]): void {
   928		const b = requireBindings();
