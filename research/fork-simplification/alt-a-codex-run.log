   287		//  - a W0 effect DRIVES renders when the value changes (a lone
   288		//    useCommitted consumer otherwise never re-renders — no watcher, no
   289		//    commit, no committed movement);
   290		//  - the committedEffect recheck advances the render one more step
   291		//    after each commit (the render that a W0 change forces still reads
   292		//    the PRE-commit view — "on screen" trails by exactly one commit).
   293		// eslint-disable-next-line react-hooks/exhaustive-deps
   294		React.useEffect(() => {
