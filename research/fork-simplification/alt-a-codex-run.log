   350			let result: unknown;
   351			api.batch(() => {
   352				result = scope();
   353			});
   354			return result as undefined; // a thenable keeps the action pending
   355		});
   356	}
   357	
   358	/** `useTransition` wrapped the same way; `isPending` is React's own. */
   359	export function useSignalTransition(): [boolean, (scope: () => unknown) => void] {
   360		const { api } = requireActive();
   361		const [isPending, start] = React.useTransition();
