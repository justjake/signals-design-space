   297				void (h as { state?: unknown }).state; // raw read: boxes never throw
   298				if (first) {
   299					return; // the mount run
   300				}
   301				force();
   302			});
   303			first = false;
   304			let firstCommitted = true;
   305			const disposeCommitted = engine.committedEffect(containerRef.current, () => {
   306				// Tracked committed read: registers the leaf dependency set the
   307				// recheck watches.
   308				void (h as { state?: unknown }).state;
   309				if (firstCommitted) {
   310					firstCommitted = false;
   311					return;
   312				}
   313				force();
   314			});
