   363			(scope: () => unknown) => {
   364				start((): void => {
   365					let result: unknown;
   366					api.batch(() => {
   367						result = scope();
   368					});
   369					return result as undefined;
   370				});
   371			},
   372			[api, start],
   373		);
   374		return [isPending, startSignal];
   375	}

