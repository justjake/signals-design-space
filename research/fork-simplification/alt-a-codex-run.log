     1	/**
     2	 * The REAL-React bridge: adapts the patched React build's external-runtime
     3	 * protocol (the "v2" surface that actually ships in vendor/react — see the
     4	 * mapping below) onto this engine's existing §6 ForkAdapter interface. The
     5	 * fork test double keeps serving the unit suites; this bridge is what a real
     6	 * app (and the seam benchmark) attaches.
     7	 *
     8	 * Protocol mapping (real fork → spec §6, gaps documented):
     9	 *
    10	 *  real surface                              → §6 event this engine speaks
    11	 *  ------------------------------------------------------------------------
    12	 *  unstable_registerBatchIdAllocator(cb)     → token minting is OURS: React
    13	 *    asks the bridge for an id at every batch's creation, with the deferred
    14	 *    classification; we mint the spec §6.2 encoding `(serial<<1)|deferred`,
    15	 *    so bit 0 keeps answering isCurrentWriteDeferred with no second call and
    16	 *    the engine's slot interning works unchanged. No mapping tables.
    17	 *  (none)                                    → onRootRegistered: the real
    18	 *    fork has no root-registration edge; the bridge synthesizes activation
    19	 *    at attach time. Sound for variant A: attach precedes any React work,
    20	 *    so flipping the monotonic write gate EARLIER than §9.1's edge only
    21	 *    widens the always-log window (never narrows it).
    22	 *  onRenderPassStart(container, included)    → same (lineage constant 0).
    23	 *    The real fork carries no render lineage (§6.3) and none is needed: the
    24	 *    Solid-adapted async model keys thenable identity on node×world (pass
    25	 *    worlds key on their include MASK — stable across restarts and Suspense
    26	 *    retries of one logical work, distinct for interleaved works whose
    27	 *    batch sets differ).
    28	 *  onRenderPassYield/Resume(container)       → identical.
    29	 *  onRenderPassEnd(container, committed)     → onRenderPassEnd(container);
    30	 *    the commit/discard bit is not needed by this engine's pass handling
    31	 *    (sweep runs either way; per-root committed truth rides the commit
    32	 *    report below).
    33	 *  onRootCommitted(container, batches, gen)  → onBatchCommitted(container,
    34	 *    batch) per reported batch (the engine's per-root committed views treat
    35	 *    re-reports as idempotent lock-in adds).
    36	 *  onBatchRetired(id, committed)             → identical.
    37	 *  unstable_getCurrentWriteBatch()           → getCurrentWriteBatch();
    38	 *    BATCH_NONE (0) reaches the engine's pseudo-batch degradation
    39	 *    (applied + retired-at-append) — by protocol it is unreachable once a
    40	 *    renderer registered its provider.
    41	 *  unstable_runInBatch(id, fn)               → runInBatch; the real fork
    42	 *    handles retired/unknown ids ITSELF (documented discrete-urgent
    43	 *    fallback), so the adapter always reports true and the engine's own
    44	 *    fallback branch becomes unreachable.
    45	 *  unstable_getRenderContext()               → null → undefined.
    46	 *
    47	 *  Async actions: the fork keeps a transition batch pending across an async
    48	 *  action and reports retirement at settlement; the bridge simply follows
    49	 *  the retirement report (no engine-side parking). Post-await writes
    50	 *  classify at their own moment — urgent unless re-wrapped — matching
    51	 *  React's own transition rule.
    52	 */
    53	import * as React from 'react';
    54	import type { CosignalEngine, Container } from '../engine';
    55	import type { ExternalRuntimeListener, ForkAdapter } from '../fork-double';
    56	
    57	/** The patched build's protocol exports (feature-detected, §6.7 skew rule). */
    58	type ForkReact = {
    59		unstable_subscribeToExternalRuntime(listener: {
    60			onRenderPassStart?: (container: unknown, includedBatches: readonly number[]) => void;
    61			onRenderPassYield?: (container: unknown) => void;
    62			onRenderPassResume?: (container: unknown) => void;
    63			onRenderPassEnd?: (container: unknown, committed: boolean) => void;
    64			onBatchRetired?: (batchId: number, committed: boolean) => void;
    65			onRootCommitted?: (container: unknown, committedBatches: readonly number[], generation: number) => void;
    66		}): () => void;
    67		unstable_registerBatchIdAllocator(allocate: (deferred: boolean) => number): () => void;
    68		unstable_getCurrentWriteBatch(): number;
    69		unstable_getRenderContext(): { container: unknown } | null;
    70		unstable_runInBatch(batchId: number, fn: () => void): unknown;
    71		unstable_resetBatchRegistryForTest?: () => void;
    72	};
    73	
    74	export function assertForkPresent(react: unknown = React): asserts react is ForkReact {
    75		const r = react as Partial<ForkReact>;
    76		if (
    77			typeof r.unstable_subscribeToExternalRuntime !== 'function'
    78			|| typeof r.unstable_registerBatchIdAllocator !== 'function'
    79		) {
    80			throw new Error(
    81				'cosignals-alt-a/react: this React build has no external-runtime protocol — '
    82				+ 'a patched React (vendor/react build, pnpm overrides) is required; stock React has none. '
    83				+ 'Building a silent degraded mode is out of scope: parity is the product (§6.7).',
    84			);
    85		}
    86	}
    87	
    88	export type ReactBridgeHandle = {
    89		engine: CosignalEngine;
    90		/** Errors thrown by engine listeners, captured (never thrown into React's
    91		 * commit — §6.7 listener-error rule). */
    92		readonly errors: unknown[];
    93		dispose(): void;
    94	};
    95	
    96	/**
    97	 * Couples the engine to the loaded patched React. Call after importing
    98	 * react-dom/client (the renderer registers its protocol provider at module
    99	 * load), before creating any root. One bridge per engine composition.
   100	 */
   101	export function attachReactBridge(engine: CosignalEngine, react: unknown = React): ReactBridgeHandle {
   102		assertForkPresent(react);
   103		const R = react;
   104		const errors: unknown[] = [];
   105		let serial = 0;
   106		let unsubscribeReact: (() => void) | undefined;
   107		// The engine assumes one open pass at a time (§6.3). The real work loop
   108		// guarantees it, but be defensive: close a stale pass before opening the
   109		// next (the same defined fall-through cosignals' shim takes).
   110		let openContainer: unknown;
   111		let passOpen = false;
   112	
   113		const adapter: ForkAdapter = {
   114			subscribeToExternalRuntime(listener: ExternalRuntimeListener): () => void {
   115				const guard = (fn: () => void): void => {
   116					try {
   117						fn();
   118					} catch (err) {
   119						errors.push(err);
   120					}
   121				};
   122				// Synthesized activation edge (§9.1): attach precedes all React work.
   123				guard(() => listener.onRootRegistered?.('react-bridge'));
   124				unsubscribeReact = R.unstable_subscribeToExternalRuntime({
   125					onRenderPassStart: (container, included) =>
   126						guard(() => {
   127							if (passOpen) {
   128								listener.onRenderPassEnd?.(openContainer);
   129							}
   130							passOpen = true;
   131							openContainer = container;
   132							// No lineage: the Solid-adapted async model keys thenable
   133							// identity on node×world (pass include-mask), so render-
   134							// attempt identity is not needed (the old synthesized
   135							// per-container lineage — and its aliasing limitation —
   136							// are deleted).
   137							listener.onRenderPassStart?.(container, included, 0);
   138						}),
   139					onRenderPassYield: (container) => guard(() => listener.onRenderPassYield?.(container)),
   140					onRenderPassResume: (container) => guard(() => listener.onRenderPassResume?.(container)),
   141					onRenderPassEnd: (container, _committed) =>
   142						guard(() => {
   143							passOpen = false;
   144							listener.onRenderPassEnd?.(container);
   145						}),
   146					onBatchRetired: (batchId, committed) => guard(() => listener.onBatchRetired?.(batchId, committed)),
   147					onRootCommitted: (container, committedBatches) =>
   148						guard(() => {
   149							for (const b of committedBatches) {
   150								listener.onBatchCommitted?.(container, b);
   151							}
   152						}),
   153				});
   154				return () => unsubscribeReact?.();
   155			},
   156			isCurrentWriteDeferred(): boolean {
   157				// Bit 0 of OUR minted token IS the classification (§6.2 encoding).
   158				return (R.unstable_getCurrentWriteBatch() & 1) === 1;
   159			},
   160			getCurrentWriteBatch(): number {
   161				return R.unstable_getCurrentWriteBatch();
   162			},
   163			getRenderContext(): { container: Container } | undefined {
   164				return R.unstable_getRenderContext() ?? undefined;
   165			},
   166			runInBatch(token: number, fn: () => void): boolean {
   167				// The real fork owns the retired-token fallback (discrete-urgent).
   168				R.unstable_runInBatch(token, fn);
   169				return true;
   170			},
   171		};
   172	
   173		// Token minting is ours: React stores the returned id as the batch's
   174		// identity for its whole life, so every protocol surface speaks the
   175		// engine's own §6.2-encoded tokens with no translation anywhere.
   176		const unregisterAllocator = R.unstable_registerBatchIdAllocator(
   177			(deferred: boolean) => ((++serial << 1) | (deferred ? 1 : 0)) | 0,
   178		);
   179		const detachEngine = engine.attachFork(adapter);
   180	
   181		return {
   182			engine,
   183			errors,
   184			dispose(): void {
   185				detachEngine();
   186				unregisterAllocator();
   187				R.unstable_resetBatchRegistryForTest?.();
   188			},
   189		};
   190	}

