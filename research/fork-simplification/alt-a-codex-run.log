   610	  /** A root was registered on `container` (createRoot/hydrateRoot), before
   611	   * any of its render work can be scheduled. Fired once per root. The write
   612	   * gate's activation edge (9.1); servers never fire it. */
   613	  onRootRegistered?: (container: Container) => void
   614	  /** A render pass began on `container`. `includedBatches` are the tokens of
   615	   * every live batch this pass renders. `lineage` is a stable integer naming
   616	   * this piece of render work across its restarts and Suspense retries (6.3).
   617	   * A pass spans yields; it ends by completing or being discarded/restarted. */
   618	  onRenderPassStart?: (container: Container, includedBatches: readonly number[], lineage: number) => void
   619	  /** The pass on `container` completed or was discarded. Exactly one end per
   620	   * start, even across restarts. */
   621	  onRenderPassEnd?: (container: Container) => void
   622	  /** The pass on `container` is yielding to the event loop (time-slicing)
   623	   * without ending; onRenderPassResume fires when it picks work back up.
   624	   * Yield and resume alternate strictly between one start and its end.
   625	   * Event handlers, timers, and microtasks run inside yield gaps — reads and
   626	   * writes there are NOT render-phase reads and writes (10.1). */
