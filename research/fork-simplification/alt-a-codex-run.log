   323	// ---- useIsPending -------------------------------------------------------------------
   324	
   325	/** Reactive pending indicator: flips only on pending↔settled transitions of
   326	 * the source (the api.isPending probe subscribed like any signal). */
   327	export function useIsPending(source: SignalSource<unknown>): boolean {
   328		const { api } = requireActive();
   329		const probe = React.useMemo(
   330			() => api.pendingProbe(handleOf(source as SignalSource<unknown>)),
